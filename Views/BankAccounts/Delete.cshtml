@model fourth_term_software_labs.Models.BankAccount

@{
    ViewData["Title"] = "Закрытие счета";
}

<h1>Закрытие банковского счета</h1>

<div class="alert alert-danger">
    <h3>Вы уверены, что хотите закрыть этот счет?</h3>
    <p>Это действие нельзя отменить.</p>
</div>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Id)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Id)</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.AccountNumber)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.AccountNumber)</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.OwnerName)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.OwnerName)</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Balance)</dt>
        <dd class="col-sm-10">@Model.Balance.ToString("N2") @Model.Currency</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Currency)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Currency)</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.IsActive)</dt>
        <dd class="col-sm-10">
            @if (Model.IsActive)
            {
                <span class="badge bg-success">Активен</span>
            }
            else
            {
                <span class="badge bg-danger">Закрыт</span>
            }
        </dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Подтвердить закрытие" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Отмена</a>
    </form>
</div>