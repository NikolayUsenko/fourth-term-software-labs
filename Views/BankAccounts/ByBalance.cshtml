@model IEnumerable<fourth_term_software_labs.Models.BankAccount>

@{
    ViewData["Title"] = ViewBag.Title;
}

<h1>@ViewBag.Title</h1>

<form method="get" class="row g-3 mb-4">
    <div class="col-auto">
        <label class="form-label">От (руб.)</label>
        <input type="number" name="min" class="form-control" placeholder="Мин. баланс" value="@ViewBag.MinBalance" step="0.01">
    </div>
    <div class="col-auto">
        <label class="form-label">До (руб.)</label>
        <input type="number" name="max" class="form-control" placeholder="Макс. баланс" value="@ViewBag.MaxBalance" step="0.01">
    </div>
    <div class="col-auto align-self-end">
        <button type="submit" class="btn btn-primary">Применить</button>
        <a asp-action="Index" class="btn btn-secondary">Сбросить</a>
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-warning">Счета не найдены в указанном диапазоне баланса</div>
}
else
{
    <p>Найдено счетов: @ViewBag.Count</p>
    
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Номер счета</th>
                <th>Владелец</th>
                <th>Баланс</th>
                <th>Валюта</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.AccountNumber</td>
                    <td>@item.OwnerName</td>
                    <td>@item.Balance.ToString("N2") @item.Currency</td>
                    <td>@item.Currency</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Детали</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}