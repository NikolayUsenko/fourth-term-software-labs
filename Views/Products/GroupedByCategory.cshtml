@model IEnumerable<fourth_term_software_labs.Models.Product>
@using System.Linq
@{
    ViewData["Title"] = "Товары по категориям";
    // Группировка выполняется прямо в представлении
    var grouped = Model.GroupBy(p => p.Category).OrderBy(g => g.Key);
}
<h1>Товары по категориям</h1>
@if (!Model.Any())
{
    <div class="alert alert-warning">
        В базе данных нет товаров. Добавьте хотя бы один товар через <a asp- action="Create">форму создания</a>.
    </div>
}
else
{
    <div class="accordion" id="categoriesAccordion">
        @{
            int index = 0;
        }
        @foreach (var group in grouped)
        {
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button @(index != 0 ? " collapsed" : "")" type="button" data-bs-toggle="collapse"
                            data-bs-target="#collapse@(index)">
                        <strong>@group.Key</strong>
                        <span class="badge bg-secondary ms-2">
                            @group.Count()
                            товаров
                        </span>
                    </button>
                </h2>
                <div id="collapse@(index)" class="accordion-collapse collapse @(index == 0 ? " show" : "")"
                     data-bs-parent="#categoriesAccordion">
                    <div class="accordion-body">
                        <table class="table table-striped table-hover">
                            <thead>
                                <tr>
                                    <th>Название</th>
                                    <th>Цена</th>
                                    <th>В наличии</th>
                                    <th>Дата добавления</th>
                                    <th>Действия</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var product in group)
                                {
                                    <tr>
                                        <td>@product.Name</td>
                                        <td class="text-primary fw-
                                            bold">
                                            @product.Price.ToString("C")
                                        </td>
                                        <td>
                                            @if (product.InStock)
                                            {
                                                <span class="badge bg-success">
                                                    В
                                                    наличии
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">
                                                    Нет в
                                                    наличии
                                                </span>
                                            }
                                        </td>
                                        <td>@product.CreatedDate.ToShortDateString()</td>
                                        <td>
                                            <a asp-action="Details" asp-route-id="@product.Id" class="btn btn-sm btn-info">Детали</a>
                                            <a asp-action="Edit" asp-route-id="@product.Id" class="btn btn-sm btn-warning">Изменить</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            index++;
        }
    </div>
}
<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">← Назад к списку</a>
    <a asp-action="Create" class="btn btn-primary">Добавить новый товар</a>
</div>
@section Scripts {
    <script>
            // Дополнительная инициализация Bootstrap аккордеона (если нужно)
            document.addEventListener('DOMContentLoaded', function () {
              // Bootstrap 5 аккордеон работает автоматически с data-bs-toggle
              console.log('Страница группировки загружена');
            });
    </script>
}
Views/Products/Paginated.cshtml
@model IEnumerable<Product>
@{
    ViewData["Title"] = "Товары (пагинация)";
}
<h1>Товары (пагинация)</h1>
<p>Страница @ViewBag.CurrentPage из @ViewBag.TotalPages</p>
<table class="table table-striped">
    <thead>
        <tr>
            <th>Название</th>
            <th>Категория</th>
            <th>Цена</th>
            <th>В наличии</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Category</td>
                <td>@item.Price.ToString("C")</td>
                <td>@(item.InStock ? "Да" : "Нет")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id">Детали</a>
                </td>
            </tr>
        }
    </tbody>
</table>
<nav>
    <ul class="pagination">
        @if (ViewBag.HasPreviousPage)
        {
            <li class="page-item">
                <a class="page-link" asp-action="Paginated" asp-route-page="@(ViewBag.CurrentPage - 1)">Назад</a>
            </li>
        }
        else
        {
            <li class="page-item disabled">
                <span class="page-link">Назад</span>
            </li>
        }
        @for (int i = 1; i <= ViewBag.TotalPages; i++)
        {
            <li class="page-item @(i == ViewBag.CurrentPage ? " active"
                                          : "" )">
        <a class="page-link" asp-action="Paginated" asp-route-page="@i">@i</a>
    </li>
}
@if (ViewBag.HasNextPage)
{
    <li class="page-item">
        <a class="page-link" asp-action="Paginated" asp-route-page="@(ViewBag.CurrentPage + 1)">Вперёд</a>
    </li>
}
else
{
    <li class="page-item disabled">
        <span class="page-link">Вперёд</span>
    </li>
}
</ul>
</nav>
<a asp-action="Index" class="btn btn-secondary">Назад</a>